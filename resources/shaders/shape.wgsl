@vertex
fn vs_main(
    in: VertexInput
) -> VertexOutput {
    var out: VertexOutput;

    let linear_color = vec4(COLOR_TO_LINEAR[in.color.r], COLOR_TO_LINEAR[in.color.g], COLOR_TO_LINEAR[in.color.b], COLOR_TO_LINEAR[in.color.a]);

    out.position = matrix * vec4(in.position, 1.0, 1.0);
    out.color = linear_color;
    out.half_size = in.half_size;
    out.radii = in.radii;
    out.mode = in.mode;
    out.local_uv = in.local_uv;

    return out;
}

@group(0) @binding(1)
var atlas: texture_2d<f32>;
@group(0) @binding(2)
var atlas_sampler: sampler;

fn sd_round_box(p: vec2<f32>, b: vec2<f32>, r: vec4<f32>) -> f32 {
    var radii = r;
    let xy = select(radii.xy, radii.wz, p.x > 0.0);

    radii.x = xy.x;
    radii.y = xy.y;
    radii.x = select(radii.x, radii.y, p.y > 0.0);

    let q = abs(p) - b + r.x;

    return min(max(q.x, q.y), 0.0) + length(max(q, vec2(0.0))) - r.x;
}

@fragment
fn fs_main(in: VertexOutput) -> @location(0) vec4<f32> {
    if in.mode == 0u {
        let d = sd_round_box(in.local_uv, in.half_size, in.radii);
        let a = 1.0 - smoothstep(-0.5, 0.5, d);

        return vec4(in.color.rgb, in.color.a * a);
    } else if in.mode == 1u {
        let mask = textureSample(atlas, atlas_sampler, in.local_uv).r;

        return vec4(in.color.rgb, in.color.a * mask);
    } else {
        return in.color;
    }
}
